# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&pgbouncer=true&connect_timeout=15"

# Direct connection (for Prisma migrations — use non-pooled URL if using Neon/Supabase)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
